# Frontend (Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend migrations (used by Alembic in CI and local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifecycle_demo

# --- GitHub Actions secrets/variables ---
# Secrets:
#   SUPABASE_ACCESS_TOKEN   — Supabase personal access token
#   VERCEL_TOKEN            — Vercel API token
#   VERCEL_ORG_ID           — from .vercel/project.json after `vercel link`
#   VERCEL_PROJECT_ID       — from .vercel/project.json after `vercel link`
#
# Variables:
#   SUPABASE_PROJECT_ID     — Supabase project ref (20 chars)
#   DEV_SUPABASE_URL        — shared dev Supabase URL (frontend-only PRs)
#   DEV_SUPABASE_ANON_KEY   — shared dev Supabase anon key
